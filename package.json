{
  "name": "taskflow",
  "version": "1.0.0",
  "description": "TaskFlow - Trello-lite REST API built with Node.js, TypeScript, and Express.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --ignore-watch node_modules --no-notify src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:generate": "prisma generate",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:db:up": "docker compose up -d postgres_test"
  },
  "keywords": [
    "express",
    "typescript",
    "rest",
    "api",
    "taskflow"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@next/env": "^15.0.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@prisma/config": "^7.0.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "pg": "^8.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^2.0.16",
    "jest": "^29.7.0",
    "prisma": "^7.4.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.0"
  }
}
